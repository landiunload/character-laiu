    private void SwitchView(string viewName)
    {
        if (_activeViewName == "relationships" && viewName != "relationships" && _graphIsInitialized)
        {
            // Canvas исчезает из DOM — рендер останавливается и переинициализируется при возврате
            _graphIsInitialized = false;
            _ = JavascriptRuntime.InvokeVoidAsync("charlaiuGraph.dispose");
        }

        _activeViewName = viewName;
