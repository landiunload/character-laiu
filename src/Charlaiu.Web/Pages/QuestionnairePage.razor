    /// <summary>
    /// Пересобирает указатель «идентификатор → герой» и список видимых связей.
    /// Зовётся один раз в начале отрисовки и перед отправкой данных в граф: списки
    /// строятся за один проход вместо перебора всех героев на каждую связь.
    /// </summary>
    private void RebuildDerivedIndexes()
    {
        _profilesByIdentifier.Clear();
        foreach (var profile in _allCharacterProfiles)
        {
            _profilesByIdentifier[profile.Identifier] = profile;
        }

        _visibleRelationships.Clear();
        foreach (var relationship in _allRelationships)
        {
            // Связь живёт, только пока живы оба участника
            if (!_profilesByIdentifier.ContainsKey(relationship.FirstCharacterIdentifier) ||
                !_profilesByIdentifier.ContainsKey(relationship.SecondCharacterIdentifier))
            {
                continue;
            }

            if (_relationshipFilterIdentifier is { } filterIdentifier &&
                relationship.FirstCharacterIdentifier != filterIdentifier &&
                relationship.SecondCharacterIdentifier != filterIdentifier)
            {
                continue;
            }

            _visibleRelationships.Add(relationship);
        }
    }

    private async Task AddRelationshipAsync()
    {
        if (_newRelationshipFirstIdentifier == Guid.Empty || _newRelationshipSecondIdentifier == Guid.Empty)
        {
            _relationshipFormMessage = "Выбери обоих персонажей.";
            return;
        }

        if (_newRelationshipFirstIdentifier == _newRelationshipSecondIdentifier)
        {
            _relationshipFormMessage = "Персонажа нельзя связать с самим собой.";
            return;
        }

        var selectedPreset = _relationshipPresets.FirstOrDefault(preset => preset.Name == _newRelationshipPresetName);
        var newRelationship = new CharacterRelationship
        {
            FirstCharacterIdentifier = _newRelationshipFirstIdentifier,
            SecondCharacterIdentifier = _newRelationshipSecondIdentifier,
            Label = selectedPreset?.Name ?? "Связь",
            ColorHex = selectedPreset?.ColorHex ?? "#888888",
            IsOneDirectional = _newRelationshipIsOneDirectional
        };

        // Дубликаты не плодятся: встречные односторонние объединяются в двустороннюю
        var mergeOutcome = RelationshipDeduplicator.ClassifyNewRelationship(_allRelationships, newRelationship);
        switch (mergeOutcome.Kind)
        {
            case RelationshipMergeOutcomeKind.Duplicate:
                _relationshipFormMessage = "Такая связь уже есть.";
                return;

            case RelationshipMergeOutcomeKind.MergedIntoBidirectional:
                mergeOutcome.ExistingRelationship!.IsOneDirectional = false;
                _relationshipFormMessage = "Встречная односторонняя связь объединена в двустороннюю.";
                break;

            default:
                _allRelationships.Add(newRelationship);
                _relationshipFormMessage = string.Empty;
                break;
        }

        await CharacterRelationshipRepository.SaveAllRelationshipsAsync(_allRelationships);
        await PushGraphDataAsync();
    }

    private async Task DeleteRelationshipAsync(Guid relationshipIdentifier)
    {
        _allRelationships.RemoveAll(relationship => relationship.Identifier == relationshipIdentifier);
        await CharacterRelationshipRepository.SaveAllRelationshipsAsync(_allRelationships);
        await PushGraphDataAsync();
    }

