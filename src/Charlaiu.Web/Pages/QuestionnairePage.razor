@page "/"
@implements IDisposable
@inject ICharacterProfileRepository CharacterProfileRepository
@inject ICharacterRelationshipRepository CharacterRelationshipRepository
@inject MarkdownQuestionnaireExporter MarkdownExporter
@inject JsonQuestionnaireExporter JsonExporter
@inject BrowserFileDownloadService FileDownloadService
@inject IJSRuntime JavascriptRuntime

<PageTitle>character laiu — анкета персонажа</PageTitle>

<div class="application-layout">
    <aside class="characters-sidebar">
        <header class="sidebar-header">
            <h1 class="application-title">character laiu</h1>
            <button class="theme-toggle-button" title="Переключить тему" @onclick="ToggleThemeAsync">
                <ApplicationIcon IconName="@(_currentThemeName == "dark" ? "lightbulb" : "moon")" Size="18" />
            </button>
        </header>

        <div class="view-switch">
            <button class="@ViewSwitchCssClass("questionnaire")" @onclick="@(() => SwitchView("questionnaire"))">Анкета</button>
            <button class="@ViewSwitchCssClass("relationships")" @onclick="@(() => SwitchView("relationships"))">Связи</button>
        </div>

        <div class="sidebar-actions">
            <button class="primary-button" @onclick="CreateCharacterProfileAsync">+ Новый герой</button>

            <div class="action-buttons-row">
                <button class="secondary-button" title="Дублировать героя" @onclick="DuplicateSelectedCharacterProfileAsync" disabled="@(_selectedCharacterProfile is null)">Копия</button>
                <button class="secondary-button" title="Открыть диалог печати" @onclick="PrintCurrentProfileAsync" disabled="@(_selectedCharacterProfile is null)">Печать</button>
                <button class="danger-button" title="Удалить героя" @onclick="DeleteSelectedCharacterProfileAsync" disabled="@(_selectedCharacterProfile is null)">Удалить</button>
            </div>

            <div class="action-buttons-row">
                <button class="secondary-button" title="Скачать готовый документ" @onclick="ExportSelectedProfileAsMarkdownAsync" disabled="@(_selectedCharacterProfile is null)">Markdown</button>
                <button class="secondary-button" title="Скачать резервную копию" @onclick="ExportSelectedProfileAsJsonAsync" disabled="@(_selectedCharacterProfile is null)">JSON</button>
                <label class="secondary-button import-label" title="Загрузить героя из файла">
                    Импорт
                    <InputFile OnChange="ImportProfileFromJsonAsync" accept=".json" class="hidden-file-input" />
                </label>
            </div>
        </div>

        <ul class="characters-list">
            @foreach (var categoryGroup in _allCharacterProfiles
                .GroupBy(profile => string.IsNullOrWhiteSpace(profile.Category) ? "Без категории" : profile.Category.Trim())
                .OrderBy(group => group.Key == "Без категории" ? 1 : 0)
                .ThenBy(group => group.Key))
            {
                <li class="category-item">
                    <button class="category-toggle-button" @onclick="() => ToggleCategoryCollapsed(categoryGroup.Key)">
                        <span class="category-toggle-arrow">@(_collapsedCategoryNames.Contains(categoryGroup.Key) ? "▸" : "▾")</span>
                        <span class="category-toggle-name">@categoryGroup.Key</span>
                        <span class="category-toggle-count">@categoryGroup.Count()</span>
                    </button>
                </li>

                @if (!_collapsedCategoryNames.Contains(categoryGroup.Key))
                {
                    @foreach (var characterProfile in categoryGroup)
                    {
                        <li class="@(characterProfile.Identifier == _selectedCharacterProfile?.Identifier ? "character-item selected" : "character-item")">
                            <button class="character-select-button" @onclick="() => SelectCharacterProfile(characterProfile)">
                                @DisplayNameOf(characterProfile)
                            </button>
                        </li>
                    }
                }
            }
        </ul>
    </aside>

    @if (_activeViewName == "relationships")
    {
        <main class="relationships-view">
            <h2 class="view-heading">Связи персонажей</h2>

            @if (_allCharacterProfiles.Count < 2)
            {
                <p class="empty-state-message">Создай хотя бы двух героев — и здесь можно будет связать их дружбой, враждой или чем угодно ещё.</p>
            }
            else
            {
                <div class="relationship-form">
                    <select class="relationship-select" @bind="_newRelationshipFirstIdentifier">
                        <option value="@Guid.Empty">— первый персонаж —</option>
                        @foreach (var characterProfile in _allCharacterProfiles)
                        {
                            <option value="@characterProfile.Identifier">@DisplayNameOf(characterProfile)</option>
                        }
                    </select>

                    <select class="relationship-select" @bind="_newRelationshipPresetName" @bind:after="ApplyRelationshipPreset">
                        @foreach (var presetName in RelationshipPresets.Keys)
                        {
                            <option value="@presetName">@presetName</option>
                        }
                    </select>

                    <select class="relationship-select" @bind="_newRelationshipSecondIdentifier">
                        <option value="@Guid.Empty">— второй персонаж —</option>
                        @foreach (var characterProfile in _allCharacterProfiles)
                        {
                            <option value="@characterProfile.Identifier">@DisplayNameOf(characterProfile)</option>
                        }
                    </select>

                    <input class="relationship-label-input" placeholder="Подпись связи" @bind="_newRelationshipLabel" />

                    <label class="one-directional-checkbox" title="Стрелка от первого персонажа ко второму">
                        <input type="checkbox" @bind="_newRelationshipIsOneDirectional" /> односторонняя
                    </label>

                    <button class="primary-button" @onclick="AddRelationshipAsync">Связать</button>
                </div>

                @if (!string.IsNullOrEmpty(_relationshipFormMessage))
                {
                    <p class="form-message">@_relationshipFormMessage</p>
                }

                @if (_relationshipFilterIdentifier is not null)
                {
                    <p class="filter-banner">
                        Показаны связи героя «@NameByIdentifier(_relationshipFilterIdentifier.Value)».
                        <button class="link-button" @onclick="() => _relationshipFilterIdentifier = null">Показать все связи</button>
                    </p>
                }

                <svg class="relationships-graph" width="800" height="520"
                     @onpointermove="HandleGraphPointerMove"
                     @onpointerup="EndNodeDrag"
                     @onpointerleave="EndNodeDrag"
                     @onclick="CloseNodeContextMenu">
                    @foreach (var edge in CalculateGraphEdges())
                    {
                        <path d="@edge.PathData" fill="none" stroke="@edge.ColorHex" stroke-width="2.5" />
                        @if (edge.ArrowPointsData is not null)
                        {
                            <polygon points="@edge.ArrowPointsData" fill="@edge.ColorHex" />
                        }
                        @((MarkupString)$"<text x=\"{Fmt(edge.LabelX)}\" y=\"{Fmt(edge.LabelY)}\" class=\"graph-edge-label\" fill=\"{edge.ColorHex}\">{System.Net.WebUtility.HtmlEncode(edge.Label)}</text>")
                    }

                    @foreach (var profile in _allCharacterProfiles)
                    {
                        var nodeState = _graphNodesByIdentifier.GetValueOrDefault(profile.Identifier);
                        if (nodeState is null) { continue; }

                        <circle cx="@Fmt(nodeState.PositionX)" cy="@Fmt(nodeState.PositionY)" r="30"
                                class="@(profile.Identifier == _relationshipFilterIdentifier ? "graph-node-circle filtered" : "graph-node-circle")"
                                @onpointerdown="pointerEvent => StartNodeDrag(profile.Identifier, pointerEvent)"
                                @onpointerdown:preventDefault
                                @oncontextmenu="pointerEvent => ShowNodeContextMenu(profile.Identifier, pointerEvent)"
                                @oncontextmenu:preventDefault />
                        @((MarkupString)$"<text x=\"{Fmt(nodeState.PositionX)}\" y=\"{Fmt(nodeState.PositionY + 48)}\" class=\"graph-node-label\">{System.Net.WebUtility.HtmlEncode(DisplayNameOf(profile))}</text>")
                    }
                </svg>

                <p class="graph-hint">Узлы можно перетаскивать мышью — отпусти, и граф сам уляжется. Правый клик по герою — меню действий.</p>

                @if (_contextMenuNodeIdentifier is not null)
                {
                    <div class="node-context-menu" style="left:@(Fmt(_contextMenuScreenX))px; top:@(Fmt(_contextMenuScreenY))px">
                        <div class="node-context-menu-title">@NameByIdentifier(_contextMenuNodeIdentifier.Value)</div>
                        <button class="node-context-menu-item" @onclick="OpenProfileFromContextMenu">Открыть анкету</button>
                        <button class="node-context-menu-item" @onclick="() => SetContextMenuNodeIntoForm(true)">Сделать первым в связке</button>
                        <button class="node-context-menu-item" @onclick="() => SetContextMenuNodeIntoForm(false)">Сделать вторым в связке</button>
                        <button class="node-context-menu-item" @onclick="FilterByContextMenuNode">Только его связи</button>
                    </div>
                }

                @if (VisibleRelationships().Any())
                {
                    <ul class="relationships-list">
                        @foreach (var relationship in VisibleRelationships())
                        {
                            <li class="relationship-item">
                                <span class="relationship-color-dot" style="background:@relationship.ColorHex"></span>
                                <span>
                                    @NameByIdentifier(relationship.FirstCharacterIdentifier)
                                    @(relationship.IsOneDirectional ? " → " : " — ")<strong>@relationship.Label</strong>@(relationship.IsOneDirectional ? " → " : " — ")@NameByIdentifier(relationship.SecondCharacterIdentifier)
                                </span>
                                <button class="icon-button" title="Удалить связь" @onclick="() => DeleteRelationshipAsync(relationship.Identifier)">✕</button>
                            </li>
                        }
                    </ul>
                }
            }
        </main>
    }
    else
    {
    <main class="questionnaire-editor">
        @if (_selectedCharacterProfile is null)
        {
            <p class="empty-state-message">Создай первого героя кнопкой «Новый герой».</p>
        }
        else
        {
            <input class="character-name-input"
                   value="@_selectedCharacterProfile.DisplayName"
                   placeholder="Имя героя"
                   @oninput="OnCharacterNameChangedAsync" />

            <div class="category-row">
                <span class="category-row-label">Категория:</span>
                <input class="category-input" placeholder="например, Главные или Злодеи"
                       @bind="_selectedCharacterProfile.Category" @bind:after="PersistChangesAsync" />
            </div>

            @foreach (var (section, sectionIndex) in _selectedCharacterProfile.Sections.Select((value, index) => (value, index)))
            {
                <section class="questionnaire-section">
                    <header class="section-header">
                        <span class="icon-picker-anchor">
                            <button class="section-icon-button" title="Выбрать иконку раздела" @onclick="() => ToggleIconPicker(section.Identifier)">
                                <ApplicationIcon IconName="@section.Icon" Size="20" />
                            </button>
                            @if (_iconPickerSectionIdentifier == section.Identifier)
                            {
                                <div class="icon-picker-popup">
                                    @foreach (var iconName in IconCatalog.IconPathsByName.Keys)
                                    {
                                        <button class="icon-picker-option" title="@iconName" @onclick="() => SelectSectionIconAsync(section, iconName)">
                                            <ApplicationIcon IconName="@iconName" Size="20" />
                                        </button>
                                    }
                                </div>
                            }
                        </span>
                        <input class="section-title-input" @bind="section.Title" @bind:after="PersistChangesAsync" />
                        <span class="row-controls">
                            <button class="icon-button" title="Раздел выше" disabled="@(sectionIndex == 0)" @onclick="() => MoveSectionAsync(section.Identifier, -1)">↑</button>
                            <button class="icon-button" title="Раздел ниже" disabled="@(sectionIndex == _selectedCharacterProfile.Sections.Count - 1)" @onclick="() => MoveSectionAsync(section.Identifier, 1)">↓</button>
                            <button class="icon-button" title="Удалить раздел" @onclick="() => RemoveSectionAsync(section.Identifier)">✕</button>
                        </span>
                    </header>

                    @if (!string.IsNullOrWhiteSpace(section.Hint))
                    {
                        <p class="section-hint">@section.Hint</p>
                    }

                    @if (section.FirstColumnLabel is not null)
                    {
                        <div class="paired-columns-header">
                            <span></span>
                            <input class="column-label-input" title="Название первой колонки — редактируется" @bind="section.FirstColumnLabel" @bind:after="PersistChangesAsync" />
                            <input class="column-label-input" title="Название второй колонки — редактируется" @bind="section.SecondColumnLabel" @bind:after="PersistChangesAsync" />
                            <span></span>
                        </div>
                    }

                    @foreach (var (field, fieldIndex) in section.Fields.Select((value, index) => (value, index)))
                    {
                        <div class="@FieldRowCssClass(field)">
                            <textarea class="field-label-input" rows="1" @bind="field.Label" @bind:after="PersistChangesAsync"></textarea>

                            <textarea class="field-value-textarea" rows="1" @bind="field.PrimaryValue" @bind:after="PersistChangesAsync"></textarea>
                            @if (field.FieldType == QuestionnaireFieldType.PairedValues)
                            {
                                <textarea class="field-value-textarea" rows="1" @bind="field.SecondaryValue" @bind:after="PersistChangesAsync"></textarea>
                            }

                            <span class="row-controls">
                                <button class="icon-button" title="Поле выше" disabled="@(fieldIndex == 0)" @onclick="() => MoveFieldAsync(section, field.Identifier, -1)">↑</button>
                                <button class="icon-button" title="Поле ниже" disabled="@(fieldIndex == section.Fields.Count - 1)" @onclick="() => MoveFieldAsync(section, field.Identifier, 1)">↓</button>
                                <button class="icon-button" title="Удалить поле" @onclick="() => RemoveFieldAsync(section, field.Identifier)">✕</button>
                            </span>
                        </div>
                    }

                    <button class="add-field-button" @onclick="() => AddFieldAsync(section)">+ Поле</button>
                </section>
            }

            <div class="add-section-row">
                <button class="add-section-button" @onclick="() => AddSectionAsync(false)">+ Раздел</button>
                <button class="add-section-button" @onclick="() => AddSectionAsync(true)">+ Раздел с колонками</button>
            </div>
        }
    </main>
    }
</div>

@code {
    private List<CharacterProfile> _allCharacterProfiles = [];
    private List<CharacterRelationship> _allRelationships = [];
    private CharacterProfile? _selectedCharacterProfile;
    private string _currentThemeName = "light";
    private string _activeViewName = "questionnaire";
    private Guid? _iconPickerSectionIdentifier;
    private readonly HashSet<string> _collapsedCategoryNames = [];

    private Guid _newRelationshipFirstIdentifier = Guid.Empty;
    private Guid _newRelationshipSecondIdentifier = Guid.Empty;
    private string _newRelationshipPresetName = "Дружба";
    private string _newRelationshipLabel = "Дружба";
    private bool _newRelationshipIsOneDirectional;
    private string _relationshipFormMessage = string.Empty;
    private Guid? _relationshipFilterIdentifier;

    // ----- Состояние физической модели графа -----

    /// <summary>Положение и скорость узла в физической модели графа.</summary>
    private sealed class GraphNodeState
    {
        public double PositionX;
        public double PositionY;
        public double VelocityX;
        public double VelocityY;
        public bool IsBeingDragged;
    }

    /// <summary>Готовое к отрисовке ребро графа.</summary>
    private sealed record GraphEdge(
        string PathData, string? ArrowPointsData, double LabelX, double LabelY, string Label, string ColorHex);

    private readonly Dictionary<Guid, GraphNodeState> _graphNodesByIdentifier = [];
    private Guid? _draggedNodeIdentifier;
    private double _dragPointerStartX;
    private double _dragPointerStartY;
    private double _dragNodeStartX;
    private double _dragNodeStartY;

    private Guid? _contextMenuNodeIdentifier;
    private double _contextMenuScreenX;
    private double _contextMenuScreenY;

    private readonly CancellationTokenSource _simulationCancellation = new();

    private const double GraphWidth = 800;
    private const double GraphHeight = 520;

    /// <summary>Предустановленные типы связей и их цвета на графе.</summary>
    private static readonly IReadOnlyDictionary<string, string> RelationshipPresets = new Dictionary<string, string>
    {
        ["Дружба"] = "#3a9d5d",
        ["Вражда"] = "#c0392b",
        ["Любовь"] = "#d4628f",
        ["Семья"] = "#4a78c2",
        ["Соперничество"] = "#b8772a",
        ["Другое"] = "#888888"
    };

    /// <summary>Загружает данные и запускает цикл физической анимации графа.</summary>
    protected override async Task OnInitializedAsync()
    {
        _allCharacterProfiles = await CharacterProfileRepository.LoadAllProfilesAsync();
        _allRelationships = await CharacterRelationshipRepository.LoadAllRelationshipsAsync();
        _selectedCharacterProfile = _allCharacterProfiles.FirstOrDefault();

        var savedThemeName = await JavascriptRuntime.InvokeAsync<string>("charlaiuInterop.readSavedTheme");
        _currentThemeName = string.IsNullOrWhiteSpace(savedThemeName) ? "light" : savedThemeName;

        _ = RunGraphSimulationLoopAsync();
    }

    /// <inheritdoc />
    public void Dispose()
    {
        _simulationCancellation.Cancel();
        _simulationCancellation.Dispose();
    }

    // ----- Физическая модель графа -----

    /// <summary>
    /// Цикл анимации (~30 кадров в секунду): узлы отталкиваются друг от друга,
    /// связи работают как пружины — граф сам распределяется, избегая наложений,
    /// а отпущенный после перетаскивания узел плавно возвращается к равновесию.
    /// </summary>
    private async Task RunGraphSimulationLoopAsync()
    {
        while (!_simulationCancellation.IsCancellationRequested)
        {
            if (_activeViewName == "relationships" && _allCharacterProfiles.Count > 0)
            {
                SynchronizeGraphNodesWithProfiles();
                ApplySimulationStep();
                await InvokeAsync(StateHasChanged);
            }

            try { await Task.Delay(33, _simulationCancellation.Token); }
            catch (OperationCanceledException) { return; }
        }
    }

    /// <summary>Добавляет узлы для новых героев и убирает узлы удалённых.</summary>
    private void SynchronizeGraphNodesWithProfiles()
    {
        var existingIdentifiers = _allCharacterProfiles.Select(profile => profile.Identifier).ToHashSet();

        foreach (var staleIdentifier in _graphNodesByIdentifier.Keys.Where(key => !existingIdentifiers.Contains(key)).ToList())
        {
            _graphNodesByIdentifier.Remove(staleIdentifier);
        }

        foreach (var profile in _allCharacterProfiles.Where(profile => !_graphNodesByIdentifier.ContainsKey(profile.Identifier)))
        {
            // «Золотой угол» гарантирует, что два узла никогда не появятся в одной точке
            var angleRadians = GoldenAngleRadians * _spawnedNodesCounter++;
            _graphNodesByIdentifier[profile.Identifier] = new GraphNodeState
            {
                PositionX = GraphWidth / 2 + 160 * Math.Cos(angleRadians),
                PositionY = GraphHeight / 2 + 140 * Math.Sin(angleRadians)
            };
        }
    }

    private const double GoldenAngleRadians = 2.399963;
    private int _spawnedNodesCounter;

    /// <summary>Один шаг симуляции: отталкивание, пружины связей, притяжение к центру, затухание.</summary>
    private void ApplySimulationStep()
    {
        const double repulsionStrength = 80000;   // отталкивание узлов друг от друга
        const double springRestLength = 235;      // желаемая длина связи
        const double springStiffness = 0.025;     // жёсткость пружины-связи
        const double centeringStrength = 0.012;   // лёгкое притяжение к центру холста
        const double velocityDamping = 0.80;      // затухание скоростей — даёт плавный «выдох» графа

        var nodeStates = _graphNodesByIdentifier.Values.ToList();

        // Попарное отталкивание
        for (var firstIndex = 0; firstIndex < nodeStates.Count; firstIndex++)
        {
            for (var secondIndex = firstIndex + 1; secondIndex < nodeStates.Count; secondIndex++)
            {
                var firstNode = nodeStates[firstIndex];
                var secondNode = nodeStates[secondIndex];

                var deltaX = secondNode.PositionX - firstNode.PositionX;
                var deltaY = secondNode.PositionY - firstNode.PositionY;

                // Совпавшие узлы расталкиваем детерминированным сдвигом — иначе сила равна нулю
                if (Math.Abs(deltaX) < 0.5 && Math.Abs(deltaY) < 0.5)
                {
                    deltaX = 1.5 + firstIndex;
                    deltaY = -1.0 - secondIndex;
                }

                var squaredDistance = Math.Max(deltaX * deltaX + deltaY * deltaY, 400);
                var distance = Math.Sqrt(squaredDistance);

                var repulsionForce = repulsionStrength / squaredDistance;
                var forceX = repulsionForce * deltaX / distance;
                var forceY = repulsionForce * deltaY / distance;

                firstNode.VelocityX -= forceX;
                firstNode.VelocityY -= forceY;
                secondNode.VelocityX += forceX;
                secondNode.VelocityY += forceY;
            }
        }

        // Пружины вдоль связей
        foreach (var relationship in VisibleRelationships())
        {
            if (!_graphNodesByIdentifier.TryGetValue(relationship.FirstCharacterIdentifier, out var firstNode) ||
                !_graphNodesByIdentifier.TryGetValue(relationship.SecondCharacterIdentifier, out var secondNode))
            {
                continue;
            }

            var deltaX = secondNode.PositionX - firstNode.PositionX;
            var deltaY = secondNode.PositionY - firstNode.PositionY;
            var distance = Math.Max(Math.Sqrt(deltaX * deltaX + deltaY * deltaY), 1);

            var springForce = (distance - springRestLength) * springStiffness;
            var forceX = springForce * deltaX / distance;
            var forceY = springForce * deltaY / distance;

            firstNode.VelocityX += forceX;
            firstNode.VelocityY += forceY;
            secondNode.VelocityX -= forceX;
            secondNode.VelocityY -= forceY;
        }

        // Центрирование, затухание и перемещение
        foreach (var nodeState in nodeStates)
        {
            if (nodeState.IsBeingDragged)
            {
                nodeState.VelocityX = 0;
                nodeState.VelocityY = 0;
                continue;
            }

            nodeState.VelocityX += (GraphWidth / 2 - nodeState.PositionX) * centeringStrength;
            nodeState.VelocityY += (GraphHeight / 2 - nodeState.PositionY) * centeringStrength;

            nodeState.VelocityX *= velocityDamping;
            nodeState.VelocityY *= velocityDamping;

            nodeState.PositionX += nodeState.VelocityX;
            nodeState.PositionY += nodeState.VelocityY;

            // Узлы не выходят за край холста
            nodeState.PositionX = Math.Clamp(nodeState.PositionX, 45, GraphWidth - 45);
            nodeState.PositionY = Math.Clamp(nodeState.PositionY, 45, GraphHeight - 60);
        }
    }

    // ----- Перетаскивание узлов -----

    private void StartNodeDrag(Guid nodeIdentifier, PointerEventArgs pointerEvent)
    {
        if (!_graphNodesByIdentifier.TryGetValue(nodeIdentifier, out var nodeState)) { return; }

        _draggedNodeIdentifier = nodeIdentifier;
        nodeState.IsBeingDragged = true;
        _dragPointerStartX = pointerEvent.ClientX;
        _dragPointerStartY = pointerEvent.ClientY;
        _dragNodeStartX = nodeState.PositionX;
        _dragNodeStartY = nodeState.PositionY;
    }

    private void HandleGraphPointerMove(PointerEventArgs pointerEvent)
    {
        if (_draggedNodeIdentifier is null ||
            !_graphNodesByIdentifier.TryGetValue(_draggedNodeIdentifier.Value, out var nodeState))
        {
            return;
        }

        nodeState.PositionX = Math.Clamp(_dragNodeStartX + (pointerEvent.ClientX - _dragPointerStartX), 45, GraphWidth - 45);
        nodeState.PositionY = Math.Clamp(_dragNodeStartY + (pointerEvent.ClientY - _dragPointerStartY), 45, GraphHeight - 60);
    }

    private void EndNodeDrag()
    {
        if (_draggedNodeIdentifier is not null &&
            _graphNodesByIdentifier.TryGetValue(_draggedNodeIdentifier.Value, out var nodeState))
        {
            nodeState.IsBeingDragged = false;
        }

        _draggedNodeIdentifier = null;
    }

    // ----- Контекстное меню узла -----

    private void ShowNodeContextMenu(Guid nodeIdentifier, MouseEventArgs mouseEvent)
    {
        _contextMenuNodeIdentifier = nodeIdentifier;
        _contextMenuScreenX = mouseEvent.ClientX;
        _contextMenuScreenY = mouseEvent.ClientY;
    }

    private void CloseNodeContextMenu() => _contextMenuNodeIdentifier = null;

    private void OpenProfileFromContextMenu()
    {
        var foundProfile = _allCharacterProfiles.FirstOrDefault(profile => profile.Identifier == _contextMenuNodeIdentifier);
        if (foundProfile is not null)
        {
            _selectedCharacterProfile = foundProfile;
            _activeViewName = "questionnaire";
        }

        CloseNodeContextMenu();
    }

    private void SetContextMenuNodeIntoForm(bool asFirstParticipant)
    {
        if (_contextMenuNodeIdentifier is { } nodeIdentifier)
        {
            if (asFirstParticipant) { _newRelationshipFirstIdentifier = nodeIdentifier; }
            else { _newRelationshipSecondIdentifier = nodeIdentifier; }
        }

        CloseNodeContextMenu();
    }

    private void FilterByContextMenuNode()
    {
        _relationshipFilterIdentifier = _contextMenuNodeIdentifier;
        CloseNodeContextMenu();
    }

    // ----- Рёбра графа -----

    /// <summary>
    /// Готовит рёбра к отрисовке: параллельные связи одной пары расходятся дугами,
    /// у односторонних связей рисуется стрелка к получателю.
    /// </summary>
    private IReadOnlyList<GraphEdge> CalculateGraphEdges()
    {
        var preparedEdges = new List<GraphEdge>();

        var relationshipsByPair = VisibleRelationships()
            .Where(relationship =>
                _graphNodesByIdentifier.ContainsKey(relationship.FirstCharacterIdentifier) &&
                _graphNodesByIdentifier.ContainsKey(relationship.SecondCharacterIdentifier))
            .GroupBy(relationship =>
            {
                var orderedPair = new[] { relationship.FirstCharacterIdentifier, relationship.SecondCharacterIdentifier }
                    .OrderBy(identifier => identifier).ToArray();
                return (orderedPair[0], orderedPair[1]);
            });

        foreach (var pairGroup in relationshipsByPair)
        {
            var parallelRelationships = pairGroup.ToList();

            // Нормаль считается по каноническому порядку пары, а не по направлению связи —
            // иначе встречные связи изгибались бы в одну и ту же сторону и накладывались
            var canonicalFirstNode = _graphNodesByIdentifier[pairGroup.Key.Item1];
            var canonicalSecondNode = _graphNodesByIdentifier[pairGroup.Key.Item2];
            var canonicalDeltaX = canonicalSecondNode.PositionX - canonicalFirstNode.PositionX;
            var canonicalDeltaY = canonicalSecondNode.PositionY - canonicalFirstNode.PositionY;
            var canonicalDistance = Math.Max(Math.Sqrt(canonicalDeltaX * canonicalDeltaX + canonicalDeltaY * canonicalDeltaY), 1);
            var normalX = -canonicalDeltaY / canonicalDistance;
            var normalY = canonicalDeltaX / canonicalDistance;

            for (var parallelIndex = 0; parallelIndex < parallelRelationships.Count; parallelIndex++)
            {
                var relationship = parallelRelationships[parallelIndex];
                var sourceNode = _graphNodesByIdentifier[relationship.FirstCharacterIdentifier];
                var targetNode = _graphNodesByIdentifier[relationship.SecondCharacterIdentifier];

                // Параллельные связи расходятся дугами в обе стороны от прямой
                var arcOffset = (parallelIndex - (parallelRelationships.Count - 1) / 2.0) * 62;

                var controlX = (sourceNode.PositionX + targetNode.PositionX) / 2 + normalX * arcOffset * 2;
                var controlY = (sourceNode.PositionY + targetNode.PositionY) / 2 + normalY * arcOffset * 2;

                var pathData = $"M {Fmt(sourceNode.PositionX)} {Fmt(sourceNode.PositionY)} Q {Fmt(controlX)} {Fmt(controlY)} {Fmt(targetNode.PositionX)} {Fmt(targetNode.PositionY)}";

                // Точка кривой Безье при t = 0.5 — место подписи
                var labelX = 0.25 * sourceNode.PositionX + 0.5 * controlX + 0.25 * targetNode.PositionX;
                var labelY = 0.25 * sourceNode.PositionY + 0.5 * controlY + 0.25 * targetNode.PositionY - 7;

                string? arrowPointsData = null;
                if (relationship.IsOneDirectional)
                {
                    // Касательная кривой в конце направлена от контрольной точки к цели
                    var tangentX = targetNode.PositionX - controlX;
                    var tangentY = targetNode.PositionY - controlY;
                    var tangentLength = Math.Max(Math.Sqrt(tangentX * tangentX + tangentY * tangentY), 1);
                    var unitX = tangentX / tangentLength;
                    var unitY = tangentY / tangentLength;

                    var tipX = targetNode.PositionX - unitX * 33;
                    var tipY = targetNode.PositionY - unitY * 33;
                    var baseX = tipX - unitX * 12;
                    var baseY = tipY - unitY * 12;
                    var sideX = -unitY * 6;
                    var sideY = unitX * 6;

                    arrowPointsData = $"{Fmt(tipX)},{Fmt(tipY)} {Fmt(baseX + sideX)},{Fmt(baseY + sideY)} {Fmt(baseX - sideX)},{Fmt(baseY - sideY)}";
                }

                preparedEdges.Add(new GraphEdge(pathData, arrowPointsData, labelX, labelY, relationship.Label, relationship.ColorHex));
            }
        }

        return preparedEdges;
    }

