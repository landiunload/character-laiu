@page "/"
@implements IDisposable
@inject ICharacterProfileRepository CharacterProfileRepository
@inject ICharacterRelationshipRepository CharacterRelationshipRepository
@inject IRelationshipPresetRepository PresetRepository
@inject MarkdownQuestionnaireExporter MarkdownExporter
@inject JsonQuestionnaireExporter JsonExporter
@inject BrowserFileDownloadService FileDownloadService
@inject IJSRuntime JavascriptRuntime

<PageTitle>character laiu — анкета персонажа</PageTitle>

@{
    // Указатели строятся один раз на отрисовку — дальше разметка только читает готовое
    RebuildDerivedIndexes();
}

<div class="application-layout">
    <aside class="characters-sidebar">
        <header class="sidebar-header">
            <h1 class="application-title">character laiu</h1>
            <button class="theme-toggle-button" title="Переключить тему" @onclick="ToggleThemeAsync">
                <ApplicationIcon IconName="@(_currentThemeName == "dark" ? "lightbulb" : "moon")" Size="18" />
            </button>
        </header>

        <div class="view-switch">
            <button class="@ViewSwitchCssClass("questionnaire")" @onclick="@(() => SwitchView("questionnaire"))">Анкета</button>
            <button class="@ViewSwitchCssClass("relationships")" @onclick="@(() => SwitchView("relationships"))">Связи</button>
        </div>

        <div class="sidebar-actions">
            <button class="primary-button" @onclick="CreateCharacterProfileAsync">+ Новый герой</button>

            <div class="action-buttons-grid">
                <button class="secondary-button" title="Дублировать героя" @onclick="DuplicateSelectedCharacterProfileAsync" disabled="@(_selectedCharacterProfile is null)">Копия</button>
                <button class="secondary-button" title="Открыть диалог печати" @onclick="PrintCurrentProfileAsync" disabled="@(_selectedCharacterProfile is null)">Печать</button>
                <button class="secondary-button" title="Скачать готовый документ" @onclick="ExportSelectedProfileAsMarkdownAsync" disabled="@(_selectedCharacterProfile is null)">Markdown</button>
                <button class="secondary-button" title="Скачать резервную копию" @onclick="ExportSelectedProfileAsJsonAsync" disabled="@(_selectedCharacterProfile is null)">JSON</button>
                <label class="secondary-button import-label" title="Загрузить героя из файла">
                    Импорт
                    <InputFile OnChange="ImportProfileFromJsonAsync" accept=".json" class="hidden-file-input" />
                </label>
                <button class="danger-button" title="Удалить героя" @onclick="DeleteSelectedCharacterProfileAsync" disabled="@(_selectedCharacterProfile is null)">Удалить</button>
            </div>
        </div>

        <ul class="characters-list">
            @foreach (var categoryGroup in _allCharacterProfiles
                .GroupBy(profile => string.IsNullOrWhiteSpace(profile.Category) ? "Без категории" : profile.Category.Trim())
                .OrderBy(group => group.Key == "Без категории" ? 1 : 0)
                .ThenBy(group => group.Key, StringComparer.Ordinal))
            {
                <li class="category-item">
                    <button class="category-toggle-button" @onclick="() => ToggleCategoryCollapsed(categoryGroup.Key)">
                        <span class="category-toggle-arrow">@(_collapsedCategoryNames.Contains(categoryGroup.Key) ? "▸" : "▾")</span>
                        <span class="category-toggle-name">@categoryGroup.Key</span>
                        <span class="category-toggle-count">@categoryGroup.Count()</span>
                    </button>
                </li>

                @if (!_collapsedCategoryNames.Contains(categoryGroup.Key))
                {
                    @foreach (var characterProfile in categoryGroup)
                    {
                        <li class="@(characterProfile.Identifier == _selectedCharacterProfile?.Identifier ? "character-item selected" : "character-item")">
                            <button class="character-select-button" @onclick="() => SelectCharacterProfileAsync(characterProfile)">
                                @DisplayNameOf(characterProfile)
                            </button>
                        </li>
                    }
                }
            }
        </ul>
    </aside>

    @if (_activeViewName == "relationships")
    {
        <main class="relationships-view">
            <h2 class="view-heading">Связи персонажей</h2>

            @if (_allCharacterProfiles.Count < 2)
            {
                <p class="empty-state-message">Создай хотя бы двух героев — и здесь можно будет связать их дружбой, враждой или чем угодно ещё.</p>
            }
            else
            {
                <div class="relationship-form">
                    <select class="relationship-select" @bind="_newRelationshipFirstIdentifier">
                        <option value="@Guid.Empty">— первый персонаж —</option>
                        @foreach (var characterProfile in _allCharacterProfiles)
                        {
                            <option value="@characterProfile.Identifier">@DisplayNameOf(characterProfile)</option>
                        }
                    </select>

                    <span class="preset-picker">
                        <svg class="preset-color-dot" width="13" height="13" viewBox="0 0 13 13"><circle cx="6.5" cy="6.5" r="6" fill="@SelectedPresetColorHex()" /></svg>
                        <select class="relationship-select preset-select" @bind="_newRelationshipPresetName">
                            @foreach (var relationshipPreset in _relationshipPresets)
                            {
                                <option value="@relationshipPreset.Name">@relationshipPreset.Name</option>
                            }
                        </select>
                        <button class="preset-settings-button" title="Настроить заготовки связей" @onclick="TogglePresetEditor">⚙</button>
                    </span>

                    <select class="relationship-select" @bind="_newRelationshipSecondIdentifier">
                        <option value="@Guid.Empty">— второй персонаж —</option>
                        @foreach (var characterProfile in _allCharacterProfiles)
                        {
                            <option value="@characterProfile.Identifier">@DisplayNameOf(characterProfile)</option>
                        }
                    </select>

                    <label class="direction-toggle" title="Стрелка от первого персонажа ко второму">
                        <input type="checkbox" @bind="_newRelationshipIsOneDirectional" />
                        <span class="direction-toggle-track"><span class="direction-toggle-thumb"></span></span>
                        <span class="direction-toggle-text">односторонняя</span>
                    </label>

                    <button class="primary-button" @onclick="AddRelationshipAsync">Связать</button>
                </div>

                @if (_isPresetEditorOpen)
                {
                    <div class="preset-editor">
                        <div class="preset-editor-title">Заготовки связей</div>
                        @foreach (var relationshipPreset in _relationshipPresets)
                        {
                            <div class="preset-editor-row">
                                <input class="preset-color-input" type="color"
                                       @bind="relationshipPreset.ColorHex" @bind:after="SavePresetsAsync" />
                                <input class="preset-name-input" placeholder="Название связи"
                                       @bind="relationshipPreset.Name" @bind:after="SavePresetsAsync" />
                                <button class="icon-button" title="Удалить заготовку"
                                        disabled="@(_relationshipPresets.Count <= 1)"
                                        @onclick="() => DeletePresetAsync(relationshipPreset)">✕</button>
                            </div>
                        }
                        <button class="add-field-button" @onclick="AddPresetAsync">+ Заготовка</button>
                    </div>
                }

                @if (!string.IsNullOrEmpty(_relationshipFormMessage))
                {
                    <p class="form-message">@_relationshipFormMessage</p>
                }

                @if (_relationshipFilterIdentifier is not null)
                {
                    <p class="filter-banner">
                        Показаны связи героя «@NameByIdentifier(_relationshipFilterIdentifier.Value)».
                        <button class="link-button" @onclick="ClearRelationshipFilterAsync">Показать все связи</button>
                    </p>
                }

                <canvas id="relationships-canvas" class="relationships-graph"></canvas>

                <p class="graph-hint">Узлы можно перетаскивать мышью — отпусти, и граф сам уляжется. Правый клик по герою — меню действий.</p>

                @if (_contextMenuNodeIdentifier is not null || _contextMenuEdgeIdentifier is not null)
                {
                    <div class="context-menu-backdrop"
                         @onclick="CloseContextMenusFromBackdrop"
                         @oncontextmenu="CloseContextMenusFromBackdrop" @oncontextmenu:preventDefault></div>
                }

                @if (_contextMenuNodeIdentifier is not null)
                {
                    <div class="node-context-menu">
                        <div class="node-context-menu-title">@NameByIdentifier(_contextMenuNodeIdentifier.Value)</div>
                        <button class="node-context-menu-item" @onclick="OpenProfileFromContextMenu">Открыть анкету</button>
                        <button class="node-context-menu-item" @onclick="() => SetContextMenuNodeIntoForm(true)">Сделать первым в связке</button>
                        <button class="node-context-menu-item" @onclick="() => SetContextMenuNodeIntoForm(false)">Сделать вторым в связке</button>
                        <button class="node-context-menu-item" @onclick="FilterByContextMenuNode">Только его связи</button>
                    </div>
                }
                else if (_contextMenuEdgeIdentifier is not null && FindRelationship(_contextMenuEdgeIdentifier.Value) is { } menuRelationship)
                {
                    <div class="node-context-menu">
                        <div class="node-context-menu-title">
                            @NameByIdentifier(menuRelationship.FirstCharacterIdentifier)
                            @(menuRelationship.IsOneDirectional ? " → " : " — ")@menuRelationship.Label@(menuRelationship.IsOneDirectional ? " → " : " — ")@NameByIdentifier(menuRelationship.SecondCharacterIdentifier)
                        </div>
                        @if (menuRelationship.IsOneDirectional)
                        {
                            <button class="node-context-menu-item" @onclick="ReverseEdgeDirectionAsync">Развернуть стрелку</button>
                            <button class="node-context-menu-item" @onclick="ToggleEdgeOrientationAsync">Сделать двусторонней</button>
                        }
                        else
                        {
                            <button class="node-context-menu-item" @onclick="ToggleEdgeOrientationAsync">Сделать односторонней</button>
                        }
                        <button class="node-context-menu-item danger" @onclick="DeleteEdgeFromMenuAsync">Удалить связь</button>
                    </div>
                }

                @if (_visibleRelationships.Count > 0)
                {
                    <ul class="relationships-list">
                        @foreach (var relationship in _visibleRelationships)
                        {
                            <li class="relationship-item" data-relationship-id="@relationship.Identifier"
                                @oncontextmenu="mouseEvent => ShowRelationshipRowMenuAsync(relationship.Identifier, mouseEvent)"
                                @oncontextmenu:preventDefault>
                                <span class="drag-handle" title="Потяни, чтобы изменить порядок дуг на графе">⠿</span>
                                <svg class="relationship-color-dot" width="12" height="12" viewBox="0 0 12 12"><circle cx="6" cy="6" r="6" fill="@relationship.ColorHex" /></svg>
                                <span>
                                    @NameByIdentifier(relationship.FirstCharacterIdentifier)
                                    @(relationship.IsOneDirectional ? " → " : " — ")<strong>@relationship.Label</strong>@(relationship.IsOneDirectional ? " → " : " — ")@NameByIdentifier(relationship.SecondCharacterIdentifier)
                                </span>
                                <button class="icon-button" title="Удалить связь" @onclick="() => DeleteRelationshipAsync(relationship.Identifier)">✕</button>
                            </li>
                        }
                    </ul>
                }
            }
        </main>
    }
    else
    {
    <main class="questionnaire-editor">
        @if (_selectedCharacterProfile is null)
        {
            <p class="empty-state-message">Создай первого героя кнопкой «Новый герой».</p>
        }
        else
        {
            <input class="character-name-input"
                   value="@_selectedCharacterProfile.DisplayName"
                   placeholder="Имя героя"
                   @oninput="OnCharacterNameChangedAsync" />

            <div class="category-row">
                <span class="category-row-label">Категория:</span>
                <input class="category-input" placeholder="например, Главные или Злодеи"
                       @bind="_selectedCharacterProfile.Category" @bind:after="PersistChangesAsync" />
            </div>

            @foreach (var (section, sectionIndex) in _selectedCharacterProfile.Sections.Select((value, index) => (value, index)))
            {
                <section class="questionnaire-section">
                    <header class="section-header">
                        <span class="icon-picker-anchor">
                            <button class="section-icon-button" title="Выбрать иконку раздела" @onclick="() => ToggleIconPicker(section.Identifier)">
                                <ApplicationIcon IconName="@section.Icon" Size="20" />
                            </button>
                            @if (_iconPickerSectionIdentifier == section.Identifier)
                            {
                                <div class="icon-picker-popup">
                                    @foreach (var iconName in IconCatalog.IconPathsByName.Keys)
                                    {
                                        <button class="icon-picker-option" title="@iconName" @onclick="() => SelectSectionIconAsync(section, iconName)">
                                            <ApplicationIcon IconName="@iconName" Size="20" />
                                        </button>
                                    }
                                </div>
                            }
                        </span>
                        <input class="section-title-input" @bind="section.Title" @bind:after="PersistChangesAsync" />
                        <span class="row-controls">
                            <button class="icon-button" title="Раздел выше" disabled="@(sectionIndex == 0)" @onclick="() => MoveSectionAsync(section.Identifier, -1)">↑</button>
                            <button class="icon-button" title="Раздел ниже" disabled="@(sectionIndex == _selectedCharacterProfile.Sections.Count - 1)" @onclick="() => MoveSectionAsync(section.Identifier, 1)">↓</button>
                            <button class="icon-button" title="Удалить раздел" @onclick="() => RemoveSectionAsync(section.Identifier)">✕</button>
                        </span>
                    </header>

                    @if (!string.IsNullOrWhiteSpace(section.Hint))
                    {
                        <p class="section-hint">@section.Hint</p>
                    }

                    @if (section.FirstColumnLabel is not null)
                    {
                        <div class="paired-columns-header">
                            <span></span>
                            <input class="column-label-input" title="Название первой колонки — редактируется" @bind="section.FirstColumnLabel" @bind:after="PersistChangesAsync" />
                            <input class="column-label-input" title="Название второй колонки — редактируется" @bind="section.SecondColumnLabel" @bind:after="PersistChangesAsync" />
                            <span></span>
                        </div>
                    }

                    @foreach (var (field, fieldIndex) in section.Fields.Select((value, index) => (value, index)))
                    {
                        <div class="@FieldRowCssClass(field)">
                            <textarea class="field-label-input" rows="1" @bind="field.Label" @bind:after="PersistChangesAsync"></textarea>

                            <textarea class="field-value-textarea" rows="1" @bind="field.PrimaryValue" @bind:after="PersistChangesAsync"></textarea>
                            @if (field.FieldType == QuestionnaireFieldType.PairedValues)
                            {
                                <textarea class="field-value-textarea" rows="1" @bind="field.SecondaryValue" @bind:after="PersistChangesAsync"></textarea>
                            }

                            <span class="row-controls">
                                <button class="icon-button" title="Поле выше" disabled="@(fieldIndex == 0)" @onclick="() => MoveFieldAsync(section, field.Identifier, -1)">↑</button>
                                <button class="icon-button" title="Поле ниже" disabled="@(fieldIndex == section.Fields.Count - 1)" @onclick="() => MoveFieldAsync(section, field.Identifier, 1)">↓</button>
                                <button class="icon-button" title="Удалить поле" @onclick="() => RemoveFieldAsync(section, field.Identifier)">✕</button>
                            </span>
                        </div>
                    }

                    <button class="add-field-button" @onclick="() => AddFieldAsync(section)">+ Поле</button>
                </section>
            }

            <div class="add-section-row">
                <button class="add-section-button" @onclick="() => AddSectionAsync(false)">+ Раздел</button>
                <button class="add-section-button" @onclick="() => AddSectionAsync(true)">+ Раздел с колонками</button>
            </div>
        }
    </main>
    }
</div>

@code {
    private List<CharacterProfile> _allCharacterProfiles = [];
    private List<CharacterRelationship> _allRelationships = [];

    // Производные от двух списков выше; пересобираются в RebuildDerivedIndexes
    private readonly Dictionary<Guid, CharacterProfile> _profilesByIdentifier = [];
    private readonly List<CharacterRelationship> _visibleRelationships = [];

    private CharacterProfile? _selectedCharacterProfile;
    private string _currentThemeName = "light";
    private string _activeViewName = "questionnaire";
    private Guid? _iconPickerSectionIdentifier;
    private readonly HashSet<string> _collapsedCategoryNames = [];

    private Guid _newRelationshipFirstIdentifier = Guid.Empty;
    private Guid _newRelationshipSecondIdentifier = Guid.Empty;
    private List<RelationshipPreset> _relationshipPresets = [];
    private string _newRelationshipPresetName = string.Empty;
    private bool _isPresetEditorOpen;
    private bool _newRelationshipIsOneDirectional;
    private string _relationshipFormMessage = string.Empty;
    private Guid? _relationshipFilterIdentifier;

    /// <summary>Загружает героев, связи и заготовки; объединяет дубликаты связей.</summary>
    protected override async Task OnInitializedAsync()
    {
        _allCharacterProfiles = await CharacterProfileRepository.LoadAllProfilesAsync();
        _allRelationships = await CharacterRelationshipRepository.LoadAllRelationshipsAsync();
        _relationshipPresets = await PresetRepository.LoadAllPresetsAsync();
        _selectedCharacterProfile = _allCharacterProfiles.FirstOrDefault();
        _newRelationshipPresetName = _relationshipPresets.FirstOrDefault()?.Name ?? string.Empty;

        // Накопившиеся дубликаты связей объединяются прямо при загрузке
        if (RelationshipDeduplicator.Deduplicate(_allRelationships))
        {
            await CharacterRelationshipRepository.SaveAllRelationshipsAsync(_allRelationships);
        }

        var savedThemeName = await JavascriptRuntime.InvokeAsync<string>("charlaiuInterop.readSavedTheme");
        _currentThemeName = string.IsNullOrWhiteSpace(savedThemeName) ? "light" : savedThemeName;
    }

    /// <inheritdoc />
    public void Dispose()
    {
        _ = JavascriptRuntime.InvokeVoidAsync("charlaiuGraph.dispose");
        _dotNetReference?.Dispose();
    }

    // ----- Граф на canvas: рендер и физика в JavaScript -----

    /// <summary>Узел графа для передачи в JavaScript.</summary>
    private sealed record GraphNodeDto(string Id, string Label, bool Filtered);

    /// <summary>Ребро графа для передачи в JavaScript.</summary>
    private sealed record GraphEdgeDto(string Id, string A, string B, string Label, string Color, bool OneWay);

    private DotNetObjectReference<QuestionnairePage>? _dotNetReference;
    private bool _graphIsInitialized;

    private Guid? _contextMenuNodeIdentifier;
    private Guid? _contextMenuEdgeIdentifier;

    /// <summary>Инициализирует canvas-граф, когда вид «Связи» впервые отрисован.</summary>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_activeViewName == "relationships" && !_graphIsInitialized && _allCharacterProfiles.Count >= 2)
        {
            _graphIsInitialized = true;
            _dotNetReference ??= DotNetObjectReference.Create(this);
            await JavascriptRuntime.InvokeVoidAsync("charlaiuGraph.initialize", "relationships-canvas", _dotNetReference);
            await PushGraphDataAsync();
        }
    }

    /// <summary>Передаёт актуальные узлы и связи в JavaScript-рендер.</summary>
    private async Task PushGraphDataAsync()
    {
        if (!_graphIsInitialized) { return; }

        // Данные могли измениться после последней отрисовки — берём свежий срез
        RebuildDerivedIndexes();

        var graphNodes = _allCharacterProfiles
            .Select(profile => new GraphNodeDto(
                profile.Identifier.ToString(),
                DisplayNameOf(profile),
                profile.Identifier == _relationshipFilterIdentifier))
            .ToList();

        var graphEdges = _visibleRelationships
            .Select(relationship => new GraphEdgeDto(
                relationship.Identifier.ToString(),
                relationship.FirstCharacterIdentifier.ToString(),
                relationship.SecondCharacterIdentifier.ToString(),
                relationship.Label,
                relationship.ColorHex,
                relationship.IsOneDirectional))
            .ToList();

        await JavascriptRuntime.InvokeVoidAsync("charlaiuGraph.setData", graphNodes, graphEdges);
    }

    // ----- Контекстное меню узла (события приходят из JavaScript) -----

    // Координаты клика сюда не передаются: строгая CSP запрещает инлайновый style,
    // поэтому меню ставит на место сам JavaScript через CSSOM — там координаты уже есть.

    /// <summary>Показывает меню узла в точке клика.</summary>
    [JSInvokable]
    public void ShowNodeContextMenuFromGraph(string nodeIdentifier)
    {
        if (!Guid.TryParse(nodeIdentifier, out var parsedIdentifier)) { return; }

        _contextMenuNodeIdentifier = parsedIdentifier;
        StateHasChanged();
    }

    /// <summary>Показывает меню связи в точке клика по линии на графе.</summary>
    [JSInvokable]
    public void ShowEdgeContextMenuFromGraph(string edgeIdentifier)
    {
        if (!Guid.TryParse(edgeIdentifier, out var parsedIdentifier)) { return; }

        _contextMenuNodeIdentifier = null;
        _contextMenuEdgeIdentifier = parsedIdentifier;
        StateHasChanged();
    }

    /// <summary>Закрывает меню по клику на пустом месте графа.</summary>
    [JSInvokable]
    public void CloseNodeContextMenuFromGraph()
    {
        if (_contextMenuNodeIdentifier is null && _contextMenuEdgeIdentifier is null) { return; }

        _contextMenuNodeIdentifier = null;
        _contextMenuEdgeIdentifier = null;
        StateHasChanged();
    }

    private void CloseNodeContextMenu()
    {
        _contextMenuNodeIdentifier = null;
        _contextMenuEdgeIdentifier = null;
    }

    private CharacterRelationship? FindRelationship(Guid relationshipIdentifier) =>
        _allRelationships.FirstOrDefault(relationship => relationship.Identifier == relationshipIdentifier);

    /// <summary>Меняет местами участников односторонней связи — стрелка разворачивается.</summary>
    private async Task ReverseEdgeDirectionAsync()
    {
        if (_contextMenuEdgeIdentifier is { } edgeIdentifier && FindRelationship(edgeIdentifier) is { } relationship)
        {
            (relationship.FirstCharacterIdentifier, relationship.SecondCharacterIdentifier) =
                (relationship.SecondCharacterIdentifier, relationship.FirstCharacterIdentifier);
            await SaveRelationshipsAndRefreshAsync();
        }

        CloseNodeContextMenu();
    }

    /// <summary>Переключает связь между односторонней и двусторонней.</summary>
    private async Task ToggleEdgeOrientationAsync()
    {
        if (_contextMenuEdgeIdentifier is { } edgeIdentifier && FindRelationship(edgeIdentifier) is { } relationship)
        {
            relationship.IsOneDirectional = !relationship.IsOneDirectional;
            await SaveRelationshipsAndRefreshAsync();
        }

        CloseNodeContextMenu();
    }

    private async Task DeleteEdgeFromMenuAsync()
    {
        if (_contextMenuEdgeIdentifier is { } edgeIdentifier)
        {
            await DeleteRelationshipAsync(edgeIdentifier);
        }

        CloseNodeContextMenu();
    }

    private async Task SaveRelationshipsAndRefreshAsync()
    {
        await CharacterRelationshipRepository.SaveAllRelationshipsAsync(_allRelationships);
        await PushGraphDataAsync();
    }

    // ----- Порядок связей: перетаскивание строк списка (события приходят из JavaScript) -----

    /// <summary>Перестановка связи на место строки, на которую её уронили. Порядок задаёт раскладку дуг.</summary>
    [JSInvokable]
    public async Task ReorderRelationshipFromList(string sourceIdentifier, string targetIdentifier)
    {
        if (!Guid.TryParse(sourceIdentifier, out var parsedSource) ||
            !Guid.TryParse(targetIdentifier, out var parsedTarget) ||
            parsedSource == parsedTarget ||
            FindRelationship(parsedSource) is not { } draggedRelationship)
        {
            return;
        }

        _allRelationships.Remove(draggedRelationship);
        var targetIndex = _allRelationships.FindIndex(relationship => relationship.Identifier == parsedTarget);
        _allRelationships.Insert(targetIndex < 0 ? _allRelationships.Count : targetIndex, draggedRelationship);

        await SaveRelationshipsAndRefreshAsync();
        StateHasChanged();
    }

    private void CloseContextMenusFromBackdrop() => CloseNodeContextMenu();

    /// <summary>Правый клик по строке списка открывает то же меню действий, что и по линии на графе.</summary>
    private async Task ShowRelationshipRowMenuAsync(Guid relationshipIdentifier, MouseEventArgs mouseEvent)
    {
        _contextMenuNodeIdentifier = null;
        _contextMenuEdgeIdentifier = relationshipIdentifier;
        await JavascriptRuntime.InvokeVoidAsync(
            "charlaiuInterop.positionContextMenu", mouseEvent.ClientX, mouseEvent.ClientY);
    }

    private void OpenProfileFromContextMenu()
    {
        var foundProfile = _allCharacterProfiles.FirstOrDefault(profile => profile.Identifier == _contextMenuNodeIdentifier);
        if (foundProfile is not null)
        {
            _selectedCharacterProfile = foundProfile;
            SwitchView("questionnaire");
        }

        CloseNodeContextMenu();
    }

    private void SetContextMenuNodeIntoForm(bool asFirstParticipant)
    {
        if (_contextMenuNodeIdentifier is { } nodeIdentifier)
        {
            if (asFirstParticipant) { _newRelationshipFirstIdentifier = nodeIdentifier; }
            else { _newRelationshipSecondIdentifier = nodeIdentifier; }
        }

        CloseNodeContextMenu();
    }

    private async Task FilterByContextMenuNode()
    {
        _relationshipFilterIdentifier = _contextMenuNodeIdentifier;
        CloseNodeContextMenu();
        await PushGraphDataAsync();
    }

    /// <summary>Сбрасывает фильтр — снова показываются все связи.</summary>
    private async Task ClearRelationshipFilterAsync()
    {
        _relationshipFilterIdentifier = null;
        await PushGraphDataAsync();
    }

    // ----- Заготовки связей -----

    private void TogglePresetEditor() => _isPresetEditorOpen = !_isPresetEditorOpen;

    /// <summary>Цвет выбранной заготовки для индикатора рядом с выпадающим списком.</summary>
    private string SelectedPresetColorHex() =>
        _relationshipPresets.FirstOrDefault(preset => preset.Name == _newRelationshipPresetName)?.ColorHex ?? "#888888";

    private async Task SavePresetsAsync()
    {
        // Если выбранную заготовку переименовали или удалили — выбор следует за списком
        if (_relationshipPresets.All(preset => preset.Name != _newRelationshipPresetName))
        {
            _newRelationshipPresetName = _relationshipPresets.FirstOrDefault()?.Name ?? string.Empty;
        }

        await PresetRepository.SaveAllPresetsAsync(_relationshipPresets);
    }

